import { NextResponse } from "next/server";
import { createSupabaseServerClient } from "@/lib/supabase/server";

export const runtime = "nodejs";
export const maxDuration = 60;

const AIRTABLE_BASE_ID = "apptufHooDgBKNsNt";
const AIRTABLE_ELEVES_TABLE = "tblDdq2Sb3FOBYtVw";
const AIRTABLE_CLASSES_TABLE = "tblpHo7G9jfus5R28";

// IDs des classes créées dans Airtable
const AIRTABLE_CLASS_IDS: Record<string, string> = {
  "3GTA":  "recL9EbNIRpe63gX4",
  "3GTIM": "recL1ZWxgttckyIZk",
  "3GTM":  "recInLyLzaTTttnBU",
  "3GTS":  "recsTkJH99PZ4hJMk",
  "3GTT":  "recBb2JGhaN6C14ir",
  "3GTU":  "recA395xWCdjHfyH4",
};

function toNiceError(e: unknown): string {
  if (!e) return "Erreur inconnue";
  if (typeof e === "string") return e;
  if (typeof e === "object" && e !== null && "message" in e) return String((e as { message: unknown }).message);
  try { return JSON.stringify(e); } catch { return String(e); }
}

async function airtableBatchCreate(
  apiKey: string,
  records: { fields: Record<string, unknown> }[]
): Promise<{ id: string; fields: Record<string, unknown> }[]> {
  const results: { id: string; fields: Record<string, unknown> }[] = [];

  // Airtable limite à 10 enregistrements par requête
  for (let i = 0; i < records.length; i += 10) {
    const batch = records.slice(i, i + 10);
    const res = await fetch(
      `https://api.airtable.com/v0/${AIRTABLE_BASE_ID}/${AIRTABLE_ELEVES_TABLE}`,
      {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${apiKey}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ records: batch }),
      }
    );
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(`Airtable batch create failed: ${JSON.stringify(err)}`);
    }
    const data = await res.json() as { records: { id: string; fields: Record<string, unknown> }[] };
    results.push(...data.records);

    // Respecter le rate limit Airtable (5 req/s)
    if (i + 10 < records.length) {
      await new Promise(resolve => setTimeout(resolve, 250));
    }
  }

  return results;
}

export async function POST(req: Request) {
  try {
    const supabase = await createSupabaseServerClient();
    const { data: { user }, error: userErr } = await supabase.auth.getUser();
    if (userErr) throw userErr;
    if (!user) return NextResponse.json({ error: "Non authentifié" }, { status: 401 });

    const airtableKey = process.env.AIRTABLE_API_KEY?.trim();
    if (!airtableKey) return NextResponse.json({ error: "AIRTABLE_API_KEY manquante dans .env.local" }, { status: 500 });

    // 1. Récupérer tous les élèves Supabase sans airtable_id
    const { data: students, error: studentsErr } = await supabase
      .from("students")
      .select(`
        id, first_name, last_name, airtable_id,
        student_enrollments(class_group_id, class_groups(name))
      `)
      .is("airtable_id", null);

    if (studentsErr) throw studentsErr;
    if (!students?.length) {
      return NextResponse.json({ message: "Tous les élèves ont déjà un airtable_id.", synced: 0 });
    }

    // 2. Préparer les records Airtable
    const airtableRecords = students.map(student => {
      // Trouver la classe
      const enrollment = (student as any).student_enrollments?.[0];
      const className = (enrollment as any)?.class_groups?.name as string | undefined;
      const classAirtableId = className ? AIRTABLE_CLASS_IDS[className] : undefined;

      return {
        studentId: student.id,
        airtableRecord: {
          fields: {
            "Nom de famille": student.last_name ?? "",
            "Prénom": student.first_name ?? "",
            ...(classAirtableId ? { "Classe": [classAirtableId] } : {}),
          } as Record<string, unknown>,
        },
      };
    });

    // 3. Créer dans Airtable par batches
    const recordsToCreate = airtableRecords.map(r => r.airtableRecord);
    const created = await airtableBatchCreate(airtableKey, recordsToCreate);

    // 4. Mettre à jour Supabase avec les airtable_id retournés
    const updates = airtableRecords.map((r, i) => ({
      id: r.studentId,
      airtable_id: created[i]?.id ?? null,
    }));

    // Update par batches de 10
    let updatedCount = 0;
    for (let i = 0; i < updates.length; i += 10) {
      const batch = updates.slice(i, i + 10);
      for (const update of batch) {
        if (!update.airtable_id) continue;
        const { error: updateErr } = await supabase
          .from("students")
          .update({ airtable_id: update.airtable_id })
          .eq("id", update.id);
        if (!updateErr) updatedCount++;
      }
    }

    return NextResponse.json({
      message: `Synchronisation terminée : ${updatedCount} élèves créés dans Airtable et liés à Supabase.`,
      synced: updatedCount,
      total: students.length,
    });

  } catch (error: unknown) {
    return NextResponse.json({ error: toNiceError(error) }, { status: 500 });
  }
}

// GET : vérifier l'état de la synchronisation
export async function GET() {
  try {
    const supabase = await createSupabaseServerClient();
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return NextResponse.json({ error: "Non authentifié" }, { status: 401 });

    const { data: stats } = await supabase
      .from("students")
      .select("airtable_id");

    const total = stats?.length ?? 0;
    const synced = stats?.filter(s => s.airtable_id).length ?? 0;
    const missing = total - synced;

    return NextResponse.json({ total, synced, missing, ready: missing === 0 });
  } catch (error: unknown) {
    return NextResponse.json({ error: toNiceError(error) }, { status: 500 });
  }
}
